{
  "manifest_version": 3,
  "name": "Edge Session Recovery",
  "version": "0.2.0",
  "description": "Incremental event-log based session capture and manual checkpoint recovery for Microsoft Edge.",
  "minimum_chrome_version": "114",
  "permissions": [
    "tabs",
    "storage",
    "sessions",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Edge Session Recovery",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "preview.html",
        "preview.js",
        "ui-shared.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
